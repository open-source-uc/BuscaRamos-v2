{
  "name": "buscaramos-v2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "pnpm run prebuild:workers && next dev --turbopack",
    "prebuild:workers": "esbuild src/workers/fuse.worker.ts --bundle --format=esm --platform=browser --target=es2020 --outfile=public/workers/fuse.worker.js",
    "build": "pnpm run prebuild:workers && next build",
    "build:cf": "pnpm run prebuild:workers && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cf:build": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare preview",
    "deploy": "pnpm run cf:build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./env.d.ts",
    "api-typegen": "openapi-typescript src/lib/static-data-api/openapi.json -o src/lib/static-data-api/types.d.ts",
    "sitemap": "node scripts/generate-sitemap.mjs"
  },
  "dependencies": {
    "@fontsource-variable/instrument-sans": "^5.2.7",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-primitive": "^2.1.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.544.0",
    "next": "16.1.6",
    "openapi-fetch": "0.17.0",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "2.15.4",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "swr": "2.4.1",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3",
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "4",
    "@types/node": "20.19.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "esbuild": "^0.24.0",
    "eslint": "9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unused-imports": "4.3.0",
    "openapi-typescript": "7.13.0",
    "prettier": "^3.6.2",
    "tailwindcss": "4",
    "tw-animate-css": "^1.3.8",
    "typescript": "5",
    "vercel": "47.0.4",
    "wrangler": "4.69.0"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
